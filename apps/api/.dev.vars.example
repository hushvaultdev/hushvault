# Local secrets for `wrangler dev` (copy to .dev.vars, which is git-ignored).

ENCRYPTION_MASTER_KEY=base64-encoded-32-byte-key
JWT_SECRET=your-dev-jwt-secret

# GitHub OAuth sign-in (optional — /api/auth/github returns 503 until set).
# Create an OAuth app at https://github.com/settings/developers with callback:
#   {API_ORIGIN}/api/auth/github/callback
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
# Where to send the user after a successful sign-in (the dashboard origin).
WEB_APP_URL=http://localhost:3000
